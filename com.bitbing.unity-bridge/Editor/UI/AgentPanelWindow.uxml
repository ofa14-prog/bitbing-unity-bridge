<ui:UXML xmlns:ui="UnityEngine.UIElements">
  <ui:VisualElement class="root">

    <!-- Python server bar -->
    <ui:VisualElement class="server-bar">
      <ui:VisualElement name="serverDot" class="server-dot"/>
      <ui:Label name="serverLabel" text="Python sunucu kontrol ediliyor…" class="server-text"/>
      <ui:Button name="serverButton" text="Başlat" class="server-btn"/>
    </ui:VisualElement>

    <!-- Unity bridge connection bar -->
    <ui:VisualElement class="conn-bar">
      <ui:VisualElement name="connectionDot" class="conn-dot"/>
      <ui:Label name="connectionLabel" text="Bağlı değil" class="conn-text"/>
      <ui:Button name="connectButton" text="Bağlan" class="conn-btn"/>
    </ui:VisualElement>

    <!-- Agent status grid (2 columns x 3 rows) -->
    <ui:VisualElement name="agentCardsContainer" class="agent-grid"/>

    <!-- Chat section (grows to fill remaining space) -->
    <ui:Label text="CHAT" class="chat-title"/>
    <ui:ScrollView name="chatScrollView" class="chat-scroll">
      <ui:VisualElement name="chatContainer" class="chat-container"/>
    </ui:ScrollView>

    <!-- Prompt input row -->
    <ui:VisualElement class="input-row">
      <ui:TextField name="chatInput" class="chat-input"/>
      <ui:Button name="sendButton" text="Gönder" class="send-btn"/>
    </ui:VisualElement>

    <!-- Quick command buttons -->
    <ui:VisualElement class="cmd-row">
      <ui:Button name="playButton"         text="▶"  class="cmd-btn"/>
      <ui:Button name="stopButton"         text="⏹"  class="cmd-btn"/>
      <ui:Button name="screenshotButton"   text="📸" class="cmd-btn"/>
      <ui:Button name="refreshButton"      text="🔄" class="cmd-btn"/>
      <ui:Button name="clearLogsButton"    text="🧹" class="cmd-btn"/>
      <ui:Button name="clearConsoleButton" text="C"  class="cmd-btn"/>
    </ui:VisualElement>

  </ui:VisualElement>
</ui:UXML>
