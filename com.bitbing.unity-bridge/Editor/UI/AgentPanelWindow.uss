:root {
  --color-vates:     rgb(255, 59,  59);
  --color-diafor:    rgb(255, 214,  0);
  --color-ahbab:     rgb(  0, 230, 118);
  --color-obsidere:  rgb( 41, 121, 255);
  --color-patientia: rgb(170,   0, 255);
  --color-magnumpus: rgb(255, 109,   0);

  --bg:          rgb(26,  26,  26);
  --surface:     rgb(36,  36,  36);
  --surface2:    rgb(46,  46,  46);
  --border:      rgba(255,255,255,0.08);
  --text:        rgb(220, 220, 220);
  --text-dim:    rgb(130, 130, 130);
  --accent:      rgb( 88, 166, 255);
  --green:       rgb( 63, 185,  80);
  --red:         rgb(248,  81,  73);
}

/* ── ROOT ── */
.root {
  flex-grow: 1;
  flex-direction: column;
  background-color: var(--bg);
  padding: 6px;
}

/* ── PYTHON SERVER BAR ── */
.server-bar {
  flex-direction: row;
  align-items: center;
  background-color: var(--surface);
  border-radius: 4px;
  padding: 4px 8px;
  margin-bottom: 4px;
  border-width: 1px;
  border-color: var(--border);
}

.server-dot {
  width: 7px;
  height: 7px;
  border-radius: 4px;
  background-color: var(--text-dim);
  margin-right: 6px;
  flex-shrink: 0;
}

.server-dot.running  { background-color: var(--green); }
.server-dot.starting { background-color: rgb(210, 153, 34); }
.server-dot.error    { background-color: var(--red); }

.server-text {
  flex-grow: 1;
  font-size: 10px;
  color: var(--text-dim);
}

.server-btn {
  font-size: 10px;
  padding: 2px 8px;
}

/* ── CONNECTION BAR ── */
.conn-bar {
  flex-direction: row;
  align-items: center;
  background-color: var(--surface);
  border-radius: 4px;
  padding: 5px 8px;
  margin-bottom: 5px;
  border-width: 1px;
  border-color: var(--border);
}

.conn-dot {
  width: 8px;
  height: 8px;
  border-radius: 4px;
  background-color: var(--text-dim);
  margin-right: 6px;
  flex-shrink: 0;
}

.conn-dot.connected { background-color: var(--green); }

.conn-text {
  flex-grow: 1;
  font-size: 11px;
  color: var(--text);
}

.conn-btn {
  font-size: 10px;
  padding: 2px 8px;
}

/* ── AGENT GRID ── */
.agent-grid {
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 5px;
}

/* Each AgentStatusCard gets width 50% in C# */
.agent-card-inner {
  flex-direction: row;
  align-items: center;
  padding: 4px 5px;
  border-radius: 3px;
  border-width: 1px;
  border-color: var(--border);
  background-color: var(--surface);
  margin: 2px;
}

/* ── CHAT ── */
.chat-title {
  font-size: 10px;
  color: var(--text-dim);
  -unity-font-style: bold;
  margin-bottom: 3px;
}

.chat-scroll {
  flex-grow: 1;
  background-color: var(--surface);
  border-radius: 4px;
  border-width: 1px;
  border-color: var(--border);
  margin-bottom: 5px;
  min-height: 80px;
}

.chat-container {
  padding: 6px;
  flex-direction: column;
}

/* User bubble */
.bubble-user {
  align-self: flex-end;
  background-color: rgb(31, 111, 235);
  border-radius: 8px;
  border-bottom-right-radius: 2px;
  padding: 5px 9px;
  margin-bottom: 6px;
  max-width: 85%;
  font-size: 11px;
  color: rgb(255, 255, 255);
  white-space: normal;
}

/* System bubble */
.bubble-system {
  align-self: flex-start;
  background-color: var(--surface2);
  border-radius: 8px;
  border-bottom-left-radius: 2px;
  border-width: 1px;
  border-color: var(--border);
  padding: 5px 9px;
  margin-bottom: 6px;
  max-width: 92%;
  font-size: 11px;
  color: var(--text);
  white-space: normal;
}

/* ── INPUT ROW ── */
.input-row {
  flex-direction: row;
  align-items: stretch;
  margin-bottom: 5px;
}

.chat-input {
  flex-grow: 1;
  font-size: 11px;
  margin-right: 5px;
}

.send-btn {
  font-size: 11px;
  padding: 0 12px;
  -unity-font-style: bold;
}

/* ── QUICK COMMANDS ── */
.cmd-row {
  flex-direction: row;
  flex-wrap: wrap;
}

.cmd-btn {
  font-size: 10px;
  padding: 2px 6px;
  margin-right: 3px;
  margin-bottom: 2px;
}
